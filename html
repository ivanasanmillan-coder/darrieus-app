       <h2 class="text-lg font-semibold flex items-center gap-2"><i data-lucide="activity" class="w-5 h-5 text-cyan-400"></i> Simulación en tiempo real</h2>
       <div id="statusBadge" class="mono text-xs px-3 py-1 rounded-full bg-green-500/20 text-green-300 border border-green-500/30">
        ● ACTIVO
       </div>
      </div><!-- Turbine stage -->
      <div class="relative bg-gradient-to-b from-sky-950/50 to-slate-950/80 rounded-2xl overflow-hidden border border-slate-700/30" style="height: 340px;">
       <!-- Wind particles container -->
       <div id="windContainer" class="absolute inset-0"></div><!-- Ground line -->
       <div class="absolute bottom-0 left-0 right-0 h-8 bg-gradient-to-t from-slate-800 to-transparent"></div><!-- Turbine -->
       <div class="turbine-container">
        <svg id="turbineSvg" class="turbine-svg" width="220" height="280" viewbox="0 0 220 280">
         <!-- Tower/shaft --> <rect x="108" y="20" width="4" height="220" fill="#64748b" rx="2" /> <!-- Base platform --> <ellipse cx="110" cy="242" rx="35" ry="8" fill="#334155" /> <rect x="90" y="235" width="40" height="12" fill="#475569" rx="3" /> <!-- Top bearing --> <circle cx="110" cy="20" r="6" fill="#94a3b8" /> <circle cx="110" cy="20" r="3" fill="#cbd5e1" /> <!-- Darrieus rotor (3 vertical blades in egg-beater pattern) --> <g id="rotorBlades">
          <!-- Blade 1: Right side (curved) -->
          <path d="M 110 40 Q 165 110 145 190" stroke="#38bdf8" stroke-width="5" fill="none" stroke-linecap="round" opacity="0.9" /> <!-- Blade 2: Left side (curved) -->
          <path d="M 110 40 Q 55 110 75 190" stroke="#38bdf8" stroke-width="5" fill="none" stroke-linecap="round" opacity="0.9" /> <!-- Blade 3: Back (curved, slightly offset perspective) -->
          <path d="M 110 40 Q 110 110 110 190" stroke="#0ea5e9" stroke-width="4" fill="none" stroke-linecap="round" opacity="0.6" />
         </g> <!-- Center hub/rotor body --> <circle cx="110" cy="110" r="8" fill="#0ea5e9" /> <circle cx="110" cy="110" r="5" fill="#06b6d4" />
        </svg>
