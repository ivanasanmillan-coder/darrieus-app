        <label for="windSlider" class="text-sm font-medium text-slate-300 flex items-center gap-2"> <i data-lucide="gauge" class="w-4 h-4"></i> Velocidad del viento del día </label> <span class="mono text-xs text-slate-500">0 – 25 m/s</span>
       </div><input type="range" id="windSlider" min="0" max="25" step="0.5" value="5" class="slider-custom w-full">
       <div class="flex justify-between mt-2 mono text-[10px] text-slate-500">
