<html lang="es" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Laboratorio Eólico Darrieus</title>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&amp;family=Unbounded:wght@300;400;600;800&amp;display=swap" rel="stylesheet">
  <style>
  body {
    font-family: 'Unbounded', sans-serif;
    background: #0a1628;
    background-image: 
      radial-gradient(at 20% 10%, rgba(56, 189, 248, 0.15) 0px, transparent 50%),
      radial-gradient(at 80% 80%, rgba(34, 197, 94, 0.1) 0px, transparent 50%),
      linear-gradient(180deg, #0a1628 0%, #0f1f3a 100%);
  }
  .mono { font-family: 'Space Mono', monospace; }
  
  /* Darrieus turbine animation */
  .turbine-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1000px;
  }
  
  .turbine-svg {
    animation: spinDarrieus 3s linear infinite;
    transform-origin: 110px 110px;
  }
  
  @keyframes spinDarrieus {
    from { transform: rotateY(0deg); }
    to { transform: rotateY(360deg); }
  }
  
  /* Wind particles */
  .wind-particle {
    position: absolute;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(147, 197, 253, 0.8), transparent);
    animation: blow linear infinite;
    pointer-events: none;
  }
  
  @keyframes blow {
    0% { transform: translateX(-100px); opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { transform: translateX(calc(100% + 100px)); opacity: 0; }
  }
  
  .slider-custom {
    -webkit-appearance: none;
    appearance: none;
    height: 8px;
    background: linear-gradient(90deg, #22c55e 0%, #eab308 50%, #ef4444 100%);
    border-radius: 999px;
    outline: none;
  }
  
  .slider-custom::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #fff;
    border: 4px solid #0ea5e9;
    cursor: pointer;
    box-shadow: 0 0 20px rgba(14, 165, 233, 0.6);
    transition: transform 0.2s;
  }
  
  .slider-custom::-webkit-slider-thumb:hover {
    transform: scale(1.15);
  }
  
  .slider-custom::-moz-range-thumb {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #fff;
    border: 4px solid #0ea5e9;
    cursor: pointer;
  }
  
  .glow-text {
    text-shadow: 0 0 20px rgba(56, 189, 248, 0.5);
  }
  
  .card-glow {
    box-shadow: 0 0 40px rgba(14, 165, 233, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(34, 197, 94, 0.4); }
    50% { box-shadow: 0 0 40px rgba(34, 197, 94, 0.8); }
  }
  
  .pulse-green { animation: pulse-glow 2s ease-in-out infinite; }
  
  .step-number {
    background: linear-gradient(135deg, #0ea5e9, #22c55e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  input[type="number"]::-webkit-outer-spin-button,
  input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  input[type="number"] { -moz-appearance: textfield; }
  
  .success-flash { animation: flash 0.6s ease-out; }
  @keyframes flash {
    0% { background-color: rgba(34, 197, 94, 0.3); }
    100% { background-color: transparent; }
  }
  
  .shake { animation: shake 0.4s; }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-8px); }
    75% { transform: translateX(8px); }
  }
</style>
  <style>body { box-sizing: border-box; }</style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
 </head>
 <body class="h-full w-full text-slate-100 overflow-auto">
  <div class="w-full min-h-full p-4 md:p-8">
   <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <header class="mb-8 text-center">
     <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/30 mb-4">
