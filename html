  <script>
  // Constants
  const RHO = 1.225;      // Air density kg/m³
  const CP = 0.35;        // Darrieus power coefficient
  
  // Default config
  const defaultConfig = {
    app_title: "Laboratorio Eólico Darrieus",
    app_subtitle: "Aprende a calcular la potencia generada según la velocidad del viento",
    formula_title: "Fórmula de Potencia Eólica",
    challenge_title: "Desafío del día"
  };
  
  // State
  let currentChallenge = null;
  
  // Challenge generator
  function generateChallenge() {
    const diameters = [2, 2.5, 3, 3.5, 4];
    const heights = [2, 3, 4, 5];
    const winds = [4, 6, 7, 8, 10, 12, 15];
    
    const d = diameters[Math.floor(Math.random() * diameters.length)];
    const h = heights[Math.floor(Math.random() * heights.length)];
    const v = winds[Math.floor(Math.random() * winds.length)];
    
    const area = d * h;
    const power = 0.5 * RHO * area * Math.pow(v, 3) * CP;
    
    currentChallenge = { d, h, v, power: Math.round(power * 100) / 100 };
    
    document.getElementById('challengeText').innerHTML = 
      `Un molino Darrieus tiene <span class="text-yellow-300 font-bold">${d}m</span> de diámetro y <span class="text-yellow-300 font-bold">${h}m</span> de altura. Hoy el viento sopla a <span class="text-yellow-300 font-bold">${v} m/s</span>. ¿Cuánta potencia genera? (redondea al entero)`;
    
    document.getElementById('answerInput').value = '';
    document.getElementById('feedback').classList.add('hidden');
  }
  
  // Calculate power and update UI
  function updateCalculation() {
    const v = parseFloat(document.getElementById('windSlider').value);
    const d = parseFloat(document.getElementById('diameterInput').value) || 2;
    const h = parseFloat(document.getElementById('heightInput').value) || 2;
    
    const area = d * h;
    const vCubed = Math.pow(v, 3);
    const power = 0.5 * RHO * area * vCubed * CP;
    
    // Displays
    document.getElementById('windSpeedDisplay').textContent = v.toFixed(1);
    document.getElementById('powerDisplay').textContent = power.toFixed(0);
    document.getElementById('areaDisplay').textContent = area.toFixed(2);
    document.getElementById('vDisplay').textContent = v.toFixed(1);
    
    // Step by step
    document.getElementById('s1').textContent = `${d} × ${h} = ${area.toFixed(2)}`;
    document.getElementById('s2').textContent = `${v.toFixed(1)}³ = ${vCubed.toFixed(2)}`;
    document.getElementById('s3a').textContent = area.toFixed(2);
    document.getElementById('s3b').textContent = vCubed.toFixed(2);
    document.getElementById('finalPower').textContent = power.toFixed(2);
    document.getElementById('finalPowerKw').textContent = (power / 1000).toFixed(3);
    
    // Turbine spin speed (visual feedback)
    const turbine = document.getElementById('turbineSvg');
    if (v < 0.1) {
      turbine.style.animationPlayState = 'paused';
    } else {
      turbine.style.animationPlayState = 'running';
      const duration = Math.max(0.2, 4 - v * 0.15);
      turbine.style.animationDuration = duration + 's';
    }
    
    // Status badge
    const badge = document.getElementById('statusBadge');
    if (v < 3) {
      badge.className = 'mono text-xs px-3 py-1 rounded-full bg-slate-500/20 text-slate-300 border border-slate-500/30';
      badge.textContent = '● BAJO VIENTO';
    } else if (v > 20) {
      badge.className = 'mono text-xs px-3 py-1 rounded-full bg-red-500/20 text-red-300 border border-red-500/30';
      badge.textContent = '● PELIGRO';
    } else {
      badge.className = 'mono text-xs px-3 py-1 rounded-full bg-green-500/20 text-green-300 border border-green-500/30';
      badge.textContent = '● ÓPTIMO';
    }
  }
  
  // Wind particles
  function createWindParticles() {
    const container = document.getElementById('windContainer');
    for (let i = 0; i < 15; i++) {
      const p = document.createElement('div');
      p.className = 'wind-particle';
      p.style.top = Math.random() * 100 + '%';
      p.style.width = (30 + Math.random() * 80) + 'px';
      p.style.animationDuration = (1.5 + Math.random() * 2) + 's';
      p.style.animationDelay = (Math.random() * 3) + 's';
      container.appendChild(p);
    }
  }
  
  function updateParticleSpeed() {
    const v = parseFloat(document.getElementById('windSlider').value);
    const particles = document.querySelectorAll('.wind-particle');
    const baseSpeed = Math.max(0.5, 4 - v * 0.15);
    particles.forEach(p => {
      p.style.animationDuration = (baseSpeed + Math.random() * 0.5) + 's';
      p.style.opacity = v < 0.5 ? '0' : '1';
    });
  }
  
  // Check answer
  function checkAnswer() {
    const input = document.getElementById('answerInput');
    const feedback = document.getElementById('feedback');
    const userAnswer = parseFloat(input.value);
    
    if (isNaN(userAnswer)) {
      feedback.classList.remove('hidden');
      feedback.className = 'mt-4 p-3 rounded-lg bg-yellow-500/10 border border-yellow-500/30 text-yellow-300 text-sm';
      feedback.innerHTML = '<i data-lucide="alert-circle" class="w-4 h-4 inline"></i> Ingresa un número para verificar';
      lucide.createIcons();
      return;
    }
    
    const correct = currentChallenge.power;
    const diff = Math.abs(userAnswer - correct);
    const tolerance = correct * 0.05; // 5% tolerance
    
    feedback.classList.remove('hidden');
    
    if (diff <= tolerance || diff <= 2) {
      feedback.className = 'mt-4 p-4 rounded-lg bg-green-500/10 border border-green-500/40 text-green-300 success-flash';
      feedback.innerHTML = `
        <div class="flex items-center gap-2 font-semibold mb-1">
          <i data-lucide="party-popper" class="w-5 h-5"></i> ¡Correcto!
        </div>
        <div class="text-xs text-slate-300 mono">
          Respuesta exacta: ${correct.toFixed(2)} W (${(correct/1000).toFixed(3)} kW)
        </div>
      `;
    } else {
      feedback.className = 'mt-4 p-4 rounded-lg bg-red-500/10 border border-red-500/40 text-red-300 shake';
      const hint = userAnswer > correct ? 'demasiado alta' : 'demasiado baja';
      feedback.innerHTML = `
        <div class="flex items-center gap-2 font-semibold mb-1">
          <i data-lucide="x-circle" class="w-5 h-5"></i> Casi...
        </div>
        <div class="text-xs text-slate-300">
          Tu respuesta es ${hint}. Revisa la fórmula y prueba de nuevo.
          <div class="mono mt-1 text-slate-400">Pista: A = ${currentChallenge.d} × ${currentChallenge.h} = ${(currentChallenge.d * currentChallenge.h).toFixed(2)} m²</div>
        </div>
      `;
    }
    lucide.createIcons();
  }
  
  // Event listeners
  document.getElementById('windSlider').addEventListener('input', () => {
    updateCalculation();
    updateParticleSpeed();
  });
  document.getElementById('diameterInput').addEventListener('input', updateCalculation);
  document.getElementById('heightInput').addEventListener('input', updateCalculation);
  document.getElementById('newChallengeBtn').addEventListener('click', generateChallenge);
  document.getElementById('checkBtn').addEventListener('click', checkAnswer);
  document.getElementById('answerInput').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') checkAnswer();
  });
  
  // Initialize Element SDK
  if (window.elementSdk) {
    window.elementSdk.init({
      defaultConfig,
      onConfigChange: async (config) => {
        document.getElementById('app_title').textContent = config.app_title || defaultConfig.app_title;
        document.getElementById('app_subtitle').textContent = config.app_subtitle || defaultConfig.app_subtitle;
        document.getElementById('formula_title').textContent = config.formula_title || defaultConfig.formula_title;
        document.getElementById('challenge_title').textContent = config.challenge_title || defaultConfig.challenge_title;
      },
      mapToCapabilities: () => ({
        recolorables: [],
        borderables: [],
        fontEditable: undefined,
        fontSizeable: undefined
      }),
      mapToEditPanelValues: (config) => new Map([
        ['app_title', config.app_title || defaultConfig.app_title],
        ['app_subtitle', config.app_subtitle || defaultConfig.app_subtitle],
        ['formula_title', config.formula_title || defaultConfig.formula_title],
        ['challenge_title', config.challenge_title || defaultConfig.challenge_title]
      ])
    });
  }
  
  // Initialize
  createWindParticles();
  updateCalculation();
  updateParticleSpeed();
  generateChallenge();
  lucide.createIcons();
</script>
